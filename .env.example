PORT=3000

# memory = in-memory (dev/teste) | sheets = Google Sheets (produção) | supabase = Supabase/PostgreSQL
STORAGE_ADAPTER=memory

# Obrigatório quando STORAGE_ADAPTER=sheets
# Cole o conteúdo JSON completo da service account (em uma única linha)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ID da planilha (extraído da URL do Google Sheets)
GOOGLE_SHEETS_ID=1DsJMSMdHigZ4j7GF4b1Qwy78OD2oZoyQBVWW9zyr-30

# Obrigatório quando STORAGE_ADAPTER=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Telegram
TELEGRAM_TOKEN=your-telegram-bot-token
